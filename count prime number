import java.util.*;
 public class Solution {
    public static void  main (String arg[])
    {
        Scanner sc= new Scanner (System.in);
        int count =0;
        int n=sc.nextInt();   
        for(int i=1;i<=n;i++)
        {
            if(n%i==0){
                count++;
            }
        }
System.out.println(count);
    }
 }
