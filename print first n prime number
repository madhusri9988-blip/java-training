import java.util.*;
 public class Solution {
    public static void  main (String []args)
    {
        Scanner sc= new Scanner (System.in);
        int count=0;
        int n=sc.nextInt();   
        for (int i=2;i<=n;i++){

            for (int j= 1 ; j<=1;j++){
                if (i%j==0){
                    count++;
                }
            }
        if (count==2){
            System.out.println(i);
        }
        }
    }

 }
