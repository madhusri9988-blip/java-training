import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner dc=new Scanner (System.in);
        int n;
        int sum=0;
        n=dc.nextInt();
        int arr []= new int[50];
        for(int i=0;i<n;i++){
         arr[i]=dc.nextInt();
            if(arr[i]%2==0)
                sum=sum+arr[i];
        }
    System.out.println(sum);
    }
}
