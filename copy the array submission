import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner dc=new Scanner (System.in);
        int n=dc.nextInt();
        int m[]=new int[50];
        int s[]=new int [50];
        for(int i=0;i<n;i++){
            m[i]=dc.nextInt();
            s[i]=m[i];
            System.out.print(s[i]+" ");      
        }
        
    }
}
            
