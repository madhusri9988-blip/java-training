import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      int year;
        Scanner n=new Scanner (System.in);
        year=n.nextInt();      
     if ((year % 400 == 0) || (year % 4 == 0 && year % 100 != 0))
     {
            System.out.println("Leap Year");
        } else 
     {
            System.out.println("Not Leap Year");
        }
    }
}
