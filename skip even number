import java.util.*;
public class Solution{
    public static void main(String[]args){
        Scanner nc=new Scanner (System.in);
        int n;
        n=nc.nextInt();
        for(int i=1;i<=n;i++)
        {
            if (i%2==0){
                continue;
            }
            System.out.println(i);
        }
    }
}
