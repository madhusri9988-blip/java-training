import java.util.*;
public class Simple{
    public static void main(String[] args) 
    {
        Scanner sc=new Scanner (System.in);
        int n;
        n=sc.nextInt();
        int sumEven = 0;
        int sumOdd = 0;

        
        for (int i = 1; i <= n; i++) {
            if (i % 2 == 0) {
                sumEven += i;  
                sumOdd += i;   
            }
        }

        System.out.println("Sum of even numbers: " + sumEven);
        System.out.println("Sum of odd numbers: " + sumOdd);
    }
}
