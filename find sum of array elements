import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner b= new Scanner (System.in);
        int n ;
        n=b.nextInt();
        int sum =0;
        int []arr = new int [50];
        for (int i =0;i<n;i++){
            arr[i]=b.nextInt();
        }
        for(int i=0;i<n;i++){
            sum=sum+arr[i];
        }
        System.out.println(sum);
    }
}
