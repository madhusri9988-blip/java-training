import java.util.*;
public class Solution{
    public static void main(String[]args){
        Scanner nc=new Scanner (System.in);
        int n;
        n=nc.nextInt();
        for(int i=1;i<=n;i++)
        {
            for (int j=1;j<=i;j++)
            {
                System.out.print(i);
            }
            System.out.println();
        }
    }
}
